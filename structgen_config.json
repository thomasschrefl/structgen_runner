{
  "ollama_base_url": "http://localhost:11434/v1",
  "ollama_api_key": "ollama",

  "designer_model": "qwen2.5-coder:7b",
  "coder_model": "qwen2.5-coder:7b",
  "summarizer_model": "qwen2.5-coder:1.5b",

  "temperature": 0.15,
  "top_p": 0.9,
  "max_tokens": 3072,

  "max_code_repairs": 3,
  "max_design_revisions": 3,
  "max_uml_repairs": 3,

  "plantuml_jar_path": "./plantuml.jar",

  "smoke_test": false,

  "log_prompts": false,
  "log_prompts_include_runlog": false,

  "prompt_length_check": true,
  "prompt_token_budget": 5500,
  "prompt_estimator": "chars_div_4",
  "compress_target_tokens": 2000
}
